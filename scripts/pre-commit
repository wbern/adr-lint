#!/usr/bin/env bash
# Sample pre-commit hook for adr-lint.
#
# Install with:
#   ln -s ../../scripts/pre-commit .git/hooks/pre-commit
#
# Requires `adr-lint` on PATH and the Claude Code CLI authenticated.

set -e

if ! command -v adr-lint >/dev/null 2>&1; then
  echo "adr-lint not on PATH; skipping ADR check" >&2
  exit 0
fi

adr-lint
